{
  "name": "audit-assistant-system",
  "version": "1.0.1",
  "description": "审计助手系统 - Electron + Vue 3 + Element Plus 桌面应用",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "concurrently \"cross-env BROWSER=none vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "element-plus": "^2.7.6",
    "@element-plus/icons-vue": "^2.3.1",
    "pinia": "^2.1.7",
    "uuid": "^10.0.0",
    "vue": "^3.4.31",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "@electron/rebuild": "^3.7.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.audit.assistant",
    "productName": "审计助手系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
